# 이 파일을 복사해 .env 로 만들고 각 키 값을 채우세요.
#   Windows PowerShell: Copy-Item .env.example .env
# .env 는 git에 올라가지 않습니다(.gitignore).

# Anthropic API 키 (판매경로 AI 진단용 / 종량제 크레딧 필요)
# console.anthropic.com 에서 발급·충전
ANTHROPIC_API_KEY=여기에_본인의_API_키를_붙여넣으세요

# 사용할 Claude 모델 (기본값 사용 권장)
ANTHROPIC_MODEL=claude-sonnet-4-6

# 백엔드 서버 포트
PORT=3001

# KAMIS 농산물유통정보 API 키 (도매시장 가격 조회)
# www.kamis.or.kr 오픈API 신청
KAMIS_API_KEY=

# 농림축산식품부 공공데이터(소비 트렌드) API 키
# data.mafra.go.kr 오픈API 신청
MAFRA_API_KEY=

# 농산물 소득자료 API 키 (작목별 수익성 비교용)
# 공공데이터포털(data.go.kr) 등에서 발급받은 인증키
INCOME_API_KEY=
